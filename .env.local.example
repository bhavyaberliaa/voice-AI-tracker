# ─── AssemblyAI ──────────────────────────────────────────────────────────────
# Get your key at https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Notion ───────────────────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations
# Then share your database with the integration and copy its ID from the URL
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ─── Google Calendar ──────────────────────────────────────────────────────────
# OAuth2 access token for the user's Google account
# Set up OAuth in Google Cloud Console: https://console.cloud.google.com/
# Enable the Google Calendar API and create OAuth 2.0 credentials
GOOGLE_CALENDAR_ACCESS_TOKEN=your_google_oauth_access_token_here
# Optional: defaults to "primary" (user's main calendar)
GOOGLE_CALENDAR_ID=primary
